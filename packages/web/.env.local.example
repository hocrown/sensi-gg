# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (배포 시 설정 — 로컬 개발 시에는 불필요)
# Vercel 배포: NEXT_PUBLIC_SITE_URL=https://sensi.gg
# Supabase Dashboard > Auth > URL Configuration 에서도 동일한 URL 설정 필요:
#   - Site URL: https://sensi.gg
#   - Redirect URLs: https://sensi.gg/auth/callback
NEXT_PUBLIC_SITE_URL=

# Default guild ID (for web setup creation)
NEXT_PUBLIC_DEFAULT_GUILD_ID=your-discord-guild-id

# Discord Bot Client ID (for bot invite link on /s page)
NEXT_PUBLIC_DISCORD_CLIENT_ID=your-discord-client-id
